# =============================================================================
# Taskwondo Configuration Template
# =============================================================================
# This file is parsed by install.sh to generate .env.
# Marker values are replaced automatically:
#   __GENERATE_HEX_32__       → 64-char hex string (openssl rand -hex 32)
#   __GENERATE_PASSWORD__     → 32-char base64 string (openssl rand -base64 24)
#   __PROMPT:description [default]__ → interactive prompt (default used with -y)
#   __DERIVE:expression__     → shell expression evaluated after all vars are set
#   __COPY:VAR__              → copies value of another variable
#   __OPTIONAL__              → left empty
#
# For manual installation, lines starting with "# @manual required|optional"
# describe variables shown by install.sh --manual-setup-info.

# --- Docker Compose ---
COMPOSE_PROJECT_NAME=taskwondo

# --- Database ---
# POSTGRES_* vars configure the PostgreSQL container.
# DATABASE_URL is auto-derived from POSTGRES_* for the Go API binary.
# docker-compose overrides DATABASE_URL with container hostnames.
POSTGRES_USER=taskwondo
POSTGRES_PASSWORD=__GENERATE_PASSWORD__
POSTGRES_DB=taskwondo
POSTGRES_PORT=5432
# @manual required PostgreSQL connection string (e.g. postgres://user:pass@host:5432/dbname?sslmode=disable)
DATABASE_URL=__DERIVE:postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}?sslmode=disable__

# --- API Server ---
# @manual required Random hex string, minimum 32 chars — generate with: openssl rand -hex 32
JWT_SECRET=__GENERATE_HEX_32__
# @manual optional Token lifetime
JWT_EXPIRY=24h
# @manual optional Public URL, used for OAuth redirects and email links
BASE_URL=http://localhost:3000

# --- Initial Admin User ---
# @manual required Email for the initial admin account
ADMIN_EMAIL=__PROMPT:Admin email address [admin@taskwondo.local]__
# @manual required Password for the initial admin account — generate with: openssl rand -base64 24
ADMIN_PASSWORD=__GENERATE_PASSWORD__

# --- Storage / MinIO ---
# docker-compose overrides STORAGE_ENDPOINT with minio:9000.
MINIO_ROOT_USER=taskwondo
MINIO_ROOT_PASSWORD=__GENERATE_PASSWORD__
MINIO_BUCKET=taskwondo-attachments
# @manual required S3 access key
STORAGE_ACCESS_KEY=__COPY:MINIO_ROOT_USER__
# @manual required S3 secret key
STORAGE_SECRET_KEY=__COPY:MINIO_ROOT_PASSWORD__
# @manual required Bucket name for attachments
STORAGE_BUCKET=taskwondo-attachments
# @manual required S3-compatible endpoint (e.g. localhost:9000 or s3.amazonaws.com)
STORAGE_ENDPOINT=localhost:9000
# @manual required Use HTTPS for storage endpoint (true for AWS S3, false for local MinIO)
STORAGE_USE_SSL=false
# @manual optional S3 region
STORAGE_REGION=us-east-1
# @manual optional Max file upload size in bytes (default 50 MB)
MAX_UPLOAD_SIZE=52428800

# --- Web Server ---
# @manual optional Port exposed by the nginx container in Docker Compose (not used for manual setup)
WEB_PORT=3000

# --- Logging ---
# @manual optional Log level: debug, info, warn, error
LOG_LEVEL=debug
# @manual optional Log format: text or json
LOG_FORMAT=text

# --- Worker ---
# @manual required NATS server URL for background job processing
NATS_URL=nats://localhost:4222
# @manual optional Number of concurrent worker goroutines
WORKER_POOL_SIZE=10
# @manual optional Worker database connection pool size
WORKER_DB_POOL=10
BACKFILL_STATS=__OPTIONAL__
