# =============================================================================
# TrackForge Configuration
# =============================================================================
# Copy this file to .env and update the values.

# --- Database ---
POSTGRES_USER=trackforge
POSTGRES_PASSWORD=changeme-use-a-strong-password
POSTGRES_DB=trackforge
POSTGRES_PORT=5432
DATABASE_URL=postgres://trackforge:changeme-use-a-strong-password@postgres:5432/trackforge?sslmode=disable

# --- API Server ---
API_PORT=8080
API_HOST=0.0.0.0
JWT_SECRET=changeme-generate-a-random-string-at-least-32-chars
JWT_EXPIRY=24h
BASE_URL=http://localhost:3000

# --- Initial Admin User ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# --- Discord OAuth (optional) ---
# Create an app at https://discord.com/developers/applications
# Add redirect URI: http://localhost:5173/auth/discord/callback (dev)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# --- Web Server ---
WEB_PORT=3000

# --- SMTP (optional, required for portal email verification) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM="TrackForge <noreply@example.com>"
SMTP_TLS=true

# --- OpenTelemetry (optional) ---
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=trackforge
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# --- Portal ---
PORTAL_ENABLED=true
PORTAL_SESSION_EXPIRY=720h

# --- Logging ---
LOG_LEVEL=info
LOG_FORMAT=json
