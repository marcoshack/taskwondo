FROM golang:1.25-alpine AS builder

RUN apk add --no-cache git

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 go build -o /bin/taskwondo-worker ./cmd/worker

FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

COPY --from=builder /bin/taskwondo-worker /bin/taskwondo-worker

ENTRYPOINT ["/bin/taskwondo-worker"]
